{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scan Result",
  "type": "object",
  "required": [
    "summary",
    "overallRiskScore",
    "riskLevel",
    "assets",
    "cbom"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "overallRiskScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "riskLevel": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "cbom": {
      "type": "object"
    },
    "recommendation": {
      "type": "object"
    }
  }
}